# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL=gpt-4o
# Model for OpenAI Responses API endpoint (/api/openai-chat)
OPENAI_RESPONSES_MODEL=gpt-4.1

# Server Configuration
PORT=3000

# CARTO LiteLLM Configuration (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
CARTO_LITELLM_URL=https://litellm-gcp-us-east1.api.carto.com/v1
GEMINI_MODEL=carto::gemini-2.5-flash

# CARTO MCP Configuration

# Option 1: Multiple MCP Servers (Recommended)
# Format: name:url:apikey,name2:url2:apikey2
# Example with multiple servers:
# MCP_SERVERS=carto:https://gcp-us-east1.api.carto.com/mcp/ac_7xhfwyml:your_key,other:https://other-mcp.com:other_key
MCP_SERVERS=carto:https://gcp-us-east1.api.carto.com/mcp/ac_7xhfwyml:eyJhbGciOiJ...

# Tool Whitelists (Optional - filter specific tools per server)
# Format: MCP_WHITELIST_{SERVERNAME}=tool1,tool2,tool3
# Only the listed tools will be loaded. If not set, all tools are loaded.
# Example: Only load supermarkets tool from carto server
MCP_WHITELIST_CARTO=supermarkets

