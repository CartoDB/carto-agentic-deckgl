# Primary provider
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Optional: Additional providers
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_GENERATIVE_AI_API_KEY=...
GOOGLE_MODEL=gemini-2.5-flash

# CARTO AI provider (OpenAI-compatible with custom baseURL)
CARTO_AI_API_BASE_URL=https://your-carto-ai-endpoint.example.com/v1
CARTO_AI_API_KEY=your-carto-api-key
CARTO_AI_API_MODEL=gpt-4o
# API type: 'chat' for LiteLLM/proxies, 'responses' for native OpenAI Agents API
CARTO_AI_API_TYPE=chat

# Server
PORT=3003
# Providers: openai,google,anthropic,carto
DEFAULT_PROVIDER=openai

# MCP Server Configuration (optional)
# Connect to remote MCP servers for additional tools
CARTO_MCP_URL=https://your-mcp-server.com/mcp
CARTO_MCP_API_KEY=your-mcp-api-key

# MCP Tool Whitelist (optional)
# Comma-separated list of tool names to include from the MCP server
# If not set, all tools from the server are available
MCP_WHITELIST_CARTO=get_map,geocode,get_center
