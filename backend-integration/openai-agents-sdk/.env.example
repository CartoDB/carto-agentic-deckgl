# Provider Selection (openai or carto)
DEFAULT_PROVIDER=openai

# OpenAI Configuration (required if DEFAULT_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# CARTO AI Configuration (required if DEFAULT_PROVIDER=carto)
# OpenAI-compatible API via LiteLLM
CARTO_AI_API_BASE_URL=https://...
CARTO_AI_API_KEY=...
CARTO_AI_API_MODEL=gpt-4o

# Server
PORT=3003

# MCP Configuration (Optional)
# CARTO MCP Server for additional tools
CARTO_MCP_URL=https://...
CARTO_MCP_API_KEY=...

# Optional: Whitelist specific MCP tools (comma-separated)
# If not set, all tools from the MCP server will be available
MCP_WHITELIST_CARTO=tool1,tool2,tool3
