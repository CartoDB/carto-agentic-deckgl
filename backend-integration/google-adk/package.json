{
  "name": "backend-google-adk",
  "version": "1.0.0",
  "description": "Map AI backend using Google ADK",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mock-mcp": "MCP_MOCK_MODE=true tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "poc": "npx tsx poc/test-adk-litellm.ts",
    "poc:stream": "npx tsx poc/test-adk-litellm-stream.ts"
  },
  "dependencies": {
    "@carto/map-ai-tools": "file:../../map-ai-tools",
    "@google/adk": "^0.4.0",
    "@google/genai": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "openai": "^4.103.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
