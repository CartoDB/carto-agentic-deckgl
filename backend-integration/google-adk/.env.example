# CARTO AI Provider (same vars as other backends)
CARTO_AI_API_BASE_URL=https://your-carto-ai-endpoint.example.com/v1
CARTO_AI_API_KEY=your-carto-api-key
CARTO_AI_API_MODEL=gpt-4o

# Server
PORT=3003

# MCP Server Configuration (optional)
CARTO_MCP_URL=https://your-mcp-server.com/mcp
CARTO_MCP_API_KEY=your-mcp-api-key

# MCP Tool Whitelist (optional)
MCP_WHITELIST_CARTO=async_workflow_job_get_status_v1_0_0,async_workflow_job_get_results_v1_0_0,ai_tools_filter_pois,ai_tools_drivetime_demographics

# CARTO LDS Geocoding (optional)
CARTO_LDS_API_BASE_URL=https://gcp-us-east1.api.carto.com/v3/lds/geocoding/geocode
CARTO_LDS_API_KEY=your-lds-api-key
