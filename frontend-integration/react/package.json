    "@deck.gl/core": "^9.2.2",
    "@deck.gl/extensions": "^9.2.6",
    "@deck.gl/geo-layers": "^9.2.6",
    "@deck.gl/json": "^9.2.6",
    "@deck.gl/layers": "^9.2.2",
    "@deck.gl/mesh-layers": "^9.2.6",
    "@deck.gl/react": "^9.2.2",
    "@loaders.gl/3d-tiles": "^4.3.4",
    "@loaders.gl/compression": "^4.3.4",
