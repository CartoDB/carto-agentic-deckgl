# CARTO API Configuration
# Get your access token from https://app.carto.com/developers
VITE_API_BASE_URL=https://gcp-us-east1.api.carto.com
VITE_API_ACCESS_TOKEN=your-carto-access-token

# Communication Mode Configuration
# Set to 'false' to use WebSocket instead of HTTP Responses API
VITE_USE_HTTP=true

# HTTP API URL (used when VITE_USE_HTTP=true)
# Options:
#   - http://localhost:3000/api/openai-chat (OpenAI Responses API)
#   - http://localhost:3000/api/litellm-chat (LiteLLM SDK)
VITE_HTTP_API_URL=http://localhost:3000/api/openai-chat

# WebSocket URL (used when VITE_USE_HTTP=false)
VITE_WS_URL=ws://localhost:3000/ws
