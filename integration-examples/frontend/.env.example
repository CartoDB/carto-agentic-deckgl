# Frontend Configuration

# Communication Mode
# Set to 'true' to use HTTP streaming endpoint (/api/vercel-chat)
# Set to 'false' or leave unset to use WebSocket endpoint (/ws)
VITE_USE_HTTP=false

# API Endpoints
# WebSocket URL (used when VITE_USE_HTTP=false)
VITE_WS_URL=ws://localhost:3000/ws

# HTTP API URL (used when VITE_USE_HTTP=true)
VITE_HTTP_API_URL=http://localhost:3000/api/vercel-chat
