# SDSC 2025 Congestion Demo - Configuration

# Google Maps API Key (required for 3D tiles)
VITE_GOOGLE_API_KEY=your-google-api-key
VITE_API_BASE_URL=https://gcp-us-east1.api.carto.com

# Communication Mode
# Set to 'true' to use HTTP streaming endpoint
# Set to 'false' or leave unset to use WebSocket endpoint
VITE_USE_HTTP=false

# API Endpoints
# WebSocket URL (used when VITE_USE_HTTP=false)
VITE_WS_URL=ws://localhost:3000/ws

# HTTP API URL (used when VITE_USE_HTTP=true)
# Options:
#   - http://localhost:3000/api/litellm-chat (LiteLLM SDK - supports conversation context with previous_response_id)
#   - http://localhost:3000/api/openai-chat (OpenAI Responses API - supports conversation context)
#   - http://localhost:3000/api/vercel-chat (Vercel AI SDK - basic streaming, may have tool call issues)
VITE_HTTP_API_URL=http://localhost:3000/api/openai-chat