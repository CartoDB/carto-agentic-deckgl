{
  "name": "backend-vercel-ai",
  "version": "1.0.0",
  "description": "Map AI backend using Vercel AI SDK",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mock-mcp": "MCP_MOCK_MODE=true tsx watch src/index.ts",
